# ---- Agentic Fantasy Football OS / web ----

# WalletConnect project id (optional — only needed if you enable WalletConnect).
# OKX Wallet via injected provider works without this.
NEXT_PUBLIC_WALLETCONNECT_ID=

# Default chain: "testnet" (X Layer testnet, chainId 1952) or "mainnet" (chainId 196)
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Deployed contract addresses (fill after running the contracts deploy script;
# the deploy script also writes them to packages/shared/src/deployments.json).
NEXT_PUBLIC_PLAYER_NFT_ADDRESS=
NEXT_PUBLIC_FANTASY_LEAGUE_ADDRESS=
NEXT_PUBLIC_SCORING_ORACLE_ADDRESS=
NEXT_PUBLIC_PAYOUT_VAULT_ADDRESS=

# ---- OKX DEX (server-side payout swaps via the DEX aggregator REST API) ----
# Self-service keys: https://web3.okx.com → developer portal → create project.
OKX_DEX_API_KEY=
OKX_DEX_SECRET_KEY=
OKX_DEX_PASSPHRASE=
OKX_DEX_PROJECT_ID=
# Stablecoin to settle winnings into on claim (X Layer USDC by default; set after confirming token address).
NEXT_PUBLIC_PAYOUT_TOKEN_ADDRESS=

# ---- AI agent (server-side) ----
# Anthropic key for the live LLM agent route. Without it, the app falls back to
# the bundled deterministic heuristic engine — no key required.
ANTHROPIC_API_KEY=
