{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "compile": {
      "outputs": ["artifacts/**", "typechain-types/**", "cache/**"]
    },
    "test": {
      "dependsOn": ["^build", "compile"]
    },
    "lint": {}
  }
}
